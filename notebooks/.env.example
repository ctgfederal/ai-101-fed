# AI-101-Fed — environment template
#
# setup.sh / 00_setup.ipynb copy this file to .env on first run.
# - Hosted lab machines already have ANTHROPIC_API_KEY (or a LiteLLM key) in
#   the shell environment; the notebooks pick that up automatically and run live.
# - For an offline / air-gapped checkout, leave the key blank and run Ollama
#   locally (see README "Air-gapped labs"): set OLLAMA_BASE_URL below and switch
#   load_model("anthropic") -> load_model("ollama", "llama3.1") in the notebooks.

# Cloud provider (the notebooks default to Anthropic)
ANTHROPIC_API_KEY=

# Optional: LiteLLM / OpenAI-compatible gateway
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Optional: local / offline inference
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: request signing (notebook 08). Only needed if you enable
# security={'signing_enabled': True}; HMAC-SHA256 over the request payload.
# ARCLLM_SIGNING_KEY=
